POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_password
DB_PORT=55432

DATABASE_URL="postgresql://db_user:db_password@localhost:55432/db"



# Security Configuration
ALLOWED_ORIGINS=http://localhost:3000
